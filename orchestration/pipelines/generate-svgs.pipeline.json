{
  "id": "generate-svgs-v1",
  "mode": "generate-svgs",
  "description": "Plan and generate SVG candidates with validation and merge summary.",
  "tasks": [
    {
      "id": "topic-normalize",
      "title": "Normalize topic scope",
      "taskType": "topic-normalize",
      "execution": "system",
      "artifactType": "topic-resolution"
    },
    {
      "id": "context-pack",
      "title": "Build shared context pack",
      "taskType": "context-pack",
      "execution": "system",
      "dependsOn": ["topic-normalize"],
      "artifactType": "context-pack"
    },
    {
      "id": "svg-plan",
      "title": "Plan SVG candidates",
      "taskType": "svg-plan",
      "execution": "agent",
      "preferredAgents": ["qwen"],
      "dependsOn": ["context-pack"],
      "artifactType": "svg-plan",
      "outputSchema": "svg-plan.schema.json"
    },
    {
      "id": "svg-generation",
      "title": "Generate SVG candidates",
      "taskType": "svg-generation",
      "execution": "agent",
      "preferredAgents": ["qwen"],
      "dependsOn": ["svg-plan"],
      "artifactType": "svg-file",
      "writeIntent": "diagram"
    },
    {
      "id": "svg-validation",
      "title": "Validate SVG candidates",
      "taskType": "svg-validation",
      "execution": "agent",
      "preferredAgents": ["codex"],
      "dependsOn": ["svg-generation"],
      "artifactType": "evaluation",
      "outputSchema": "evaluation.schema.json"
    },
    {
      "id": "merge-decision",
      "title": "Summarize merge readiness",
      "taskType": "merge-decision",
      "execution": "system",
      "dependsOn": ["svg-validation"],
      "artifactType": "run-summary"
    }
  ]
}
