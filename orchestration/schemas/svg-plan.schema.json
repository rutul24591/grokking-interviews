{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SVG Plan Artifact",
  "type": "object",
  "required": ["diagrams"],
  "properties": {
    "diagrams": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["filename", "theme", "caption", "diagramType"],
        "properties": {
          "filename": { "type": "string" },
          "theme": { "type": "string" },
          "caption": { "type": "string" },
          "diagramType": { "type": "string" }
        }
      }
    }
  }
}
