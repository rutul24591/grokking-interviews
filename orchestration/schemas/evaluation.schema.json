{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evaluation Artifact",
  "type": "object",
  "required": ["pass", "score", "reasons", "blockingIssues"],
  "properties": {
    "pass": { "type": "boolean" },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blockingIssues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suggestedRepairTask": {
      "type": ["string", "null"]
    }
  }
}
