{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Article Outline Artifact",
  "type": "object",
  "required": ["title", "sections"],
  "properties": {
    "title": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heading", "summary"],
        "properties": {
          "heading": { "type": "string" },
          "summary": { "type": "string" },
          "keyPoints": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
