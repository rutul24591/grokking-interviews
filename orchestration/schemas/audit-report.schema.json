{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Audit Report Artifact",
  "type": "object",
  "required": ["articleName", "rating", "issues", "suggestions"],
  "properties": {
    "articleName": { "type": "string" },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suggestions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
