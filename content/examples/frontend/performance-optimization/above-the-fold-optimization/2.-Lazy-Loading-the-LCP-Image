// BAD: loading="lazy" on the LCP image delays its load
// The browser won't fetch it until it's near the viewport (which it already is)
<img src="/hero.webp" alt="Hero" loading="lazy" />

// GOOD: LCP image should load eagerly with high priority
<img src="/hero.webp" alt="Hero" fetchpriority="high" />

// GOOD: With preload for earliest possible discovery
<link rel="preload" href="/hero.webp" as="image" fetchpriority="high">

// Common mistake: applying loading="lazy" to ALL images
// Only below-fold images should be lazy-loaded
{products.map((product, index) => (
  <img
    key={product.id}
    src={product.image}
    alt={product.name}
    width={400}
    height={300}
    // First 4 images are likely above fold — load eagerly
    loading={index < 4 ? 'eager' : 'lazy'}
    fetchPriority={index === 0 ? 'high' : 'auto'}
  />
))}