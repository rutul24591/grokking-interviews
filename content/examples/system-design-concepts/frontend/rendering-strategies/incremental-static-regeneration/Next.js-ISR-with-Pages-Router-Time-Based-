// pages/products/[id].tsx
import type { GetStaticPaths, GetStaticProps } from 'next';

interface Product {
  id: string;
  name: string;
  description: string;
  price: number;
  stock: number;
}

interface Props {
  product: Product;
}

// Generate static pages at build time
export const getStaticPaths: GetStaticPaths = async () => {
  // Pre-render only top 100 products at build time
  const response = await fetch('https://api.example.com/products?limit=100');
  const products: Product[] = await response.json();

  const paths = products.map((product) => ({
    params: { id: product.id },
  }));

  return {
    paths,
    // Generate other pages on-demand with ISR
    fallback: 'blocking', // or true for loading state
  };
};

// Fetch data and enable ISR with revalidate
export const getStaticProps: GetStaticProps<Props> = async (context) => {
  const { id } = context.params!;

  try {
    const response = await fetch(`https://api.example.com/products/\${id}`);

    if (!response.ok) {
      return { notFound: true };
    }

    const product = await response.json();

    return {
      props: { product },
      // Revalidate every 60 seconds (stale-while-revalidate)
      revalidate: 60, // ISR enabled!
    };
  } catch (error) {
    return { notFound: true };
  }
};

export default function ProductPage({ product }: Props) {
  return (
    <article>
      <h1>{product.name}</h1>
      <p>{product.description}</p>
      <p className="text-lg font-bold">\${product.price}</p>
      <p className="text-sm">Stock: {product.stock}</p>
    </article>
  );
}