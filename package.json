{
  "name": "system-design-prep",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "generate-article-routes": "tsx scripts/generate-article-routes.ts",
    "generate-examples-manifest:requirements": "node scripts/generate-examples-manifest-requirements.js",
    "generate-examples-manifest:problems": "node scripts/generate-examples-manifest-problems.js",
    "orchestrator": "node --import tsx ./scripts/orchestrator.ts",
    "orchestrator:plan": "node --import tsx ./scripts/orchestrator.ts plan",
    "orchestrator:status": "node --import tsx ./scripts/orchestrator.ts status",
    "orchestrator:ready": "node --import tsx ./scripts/orchestrator.ts ready",
    "orchestrator:claim": "node --import tsx ./scripts/orchestrator.ts claim",
    "orchestrator:render-prompt": "node --import tsx ./scripts/orchestrator.ts render-prompt",
    "orchestrator:complete": "node --import tsx ./scripts/orchestrator.ts complete",
    "orchestrator:evaluate": "node --import tsx ./scripts/orchestrator.ts evaluate",
    "orchestrator:merge-plan": "node --import tsx ./scripts/orchestrator.ts merge-plan",
    "orchestrator:merge": "node --import tsx ./scripts/orchestrator.ts merge",
    "orchestrator:recover": "node --import tsx ./scripts/orchestrator.ts recover",
    "orchestrator:fail": "node --import tsx ./scripts/orchestrator.ts fail",
    "build": "pnpm generate-article-routes && pnpm generate-examples-manifest:requirements && next build",
    "start": "next start",
    "lint": "eslint",
    "scan:code-snippets": "tsx scripts/scan-code-snippets.ts",
    "scan:code-snippets:fix": "tsx scripts/scan-code-snippets.ts --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "orchestrator:help": "node --import tsx ./scripts/orchestrator.ts help"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "bright": "^1.0.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^1.8.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-security": "^4.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
